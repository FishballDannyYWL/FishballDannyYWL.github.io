---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 – Page Not Found">
  <div class="max-w-xl mx-auto px-4 py-24 text-center">
    <p class="text-8xl font-bold text-gray-200 mb-4">404</p>
    <h1 class="text-2xl font-semibold mb-3">Page Not Found</h1>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md transition-colors"
    >
      Go Home
    </a>
  </div>
</BaseLayout>

